generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  schemas   = ["pingpong"]
}

model User {
  id             String             @id @default(cuid())
  fluxUserId     String             @unique
  email          String?
  role           String             @default("USER")
  creditBalance  Float              @default(100.0)
  monitorSlots   Int                @default(2)
  activeSlots    Int                @default(0)
  status         String             @default("ACTIVE")
  streakCount    Int                @default(0)
  lastClaimedAt  DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  dailyCredits   DailyCreditClaim[]
  monitors       Monitor[]
  pingLogs       PingLog[]
  notifications  Notification[]
  supportTickets SupportTicket[]
  transactions   Transaction[]

  @@schema("pingpong")
}

model Notification {
  id             String   @id @default(cuid())
  title          String
  type           String   @default("SYSTEM")
  message        String
  targetAudience String   @default("ALL")
  readBy         String[]
  createdAt      DateTime @default(now())
  User           User?    @relation(fields: [userId], references: [id])
  userId         String?

  @@schema("pingpong")
}

model SupportTicket {
  id          String   @id @default(cuid())
  type        String
  userId      String
  status      String   @default("NEW")
  text        String
  browserInfo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("pingpong")
}

model GlobalSettings {
  id                  String    @id @default(cuid())
  creditCostPerPing   Float     @default(0.01389)
  globalPause         Boolean   @default(false)
  pollIntervalMs      Int       @default(1000)
  maintenanceMode     Boolean   @default(false)
  maintenanceMessage  String    @default("")
  maintenanceStart    DateTime?
  maintenanceEnd      DateTime?
  lockdownNewAccounts Boolean   @default(false)
  lockdownNewMonitors Boolean   @default(false)
  lockdownMessage     String    @default("")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@schema("pingpong")
}

model CreditPackage {
  id           String        @id @default(cuid())
  name         String
  credits      Int
  price        Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@schema("pingpong")
}

model Transaction {
  id        String        @id @default(cuid())
  userId    String
  packageId String
  amount    Float
  status    String        @default("PENDING")
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  package   CreditPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([packageId])
  @@schema("pingpong")
}

model AuditLog {
  id        String   @id @default(cuid())
  logType   String
  userId    String?
  action    String
  details   String?
  timestamp DateTime @default(now())

  @@index([logType])
  @@index([userId])
  @@schema("pingpong")
}

model Monitor {
  id               String    @id @default(cuid())
  userId           String
  serviceName      String
  targetUrl        String
  scheduleMode     String    @default("RECURRING")
  pingIntervalSecs Int?
  timeoutMs        Int       @default(10000)
  maxRetries       Int       @default(0)
  activeDays       String?
  executeTime      String?
  executeDate      DateTime?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  isCompleted      Boolean   @default(false)
  costPerPing      Float     @default(0.01389)
  lastPingedAt     DateTime?
  nextCheckAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pingLogs         PingLog[]

  @@index([userId])
  @@schema("pingpong")
}

model PingLog {
  id             String   @id @default(cuid())
  monitorId      String
  userId         String
  status         String
  responseTimeMs Int?
  statusCode     Int?
  errorMessage   String?
  checkedAt      DateTime
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitor        Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([userId])
  @@schema("pingpong")
}

model DailyCreditClaim {
  id        String   @id @default(cuid())
  userId    String
  claimedAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, claimedAt])
  @@index([userId])
  @@schema("pingpong")
}
